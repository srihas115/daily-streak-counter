SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required: signs the login session cookie. Any long random string works,
# and it's independent of your password — changing it just logs everyone
# out. Generate one with: openssl rand -hex 32
SESSION_SECRET=

# Optional: locks your deployment behind a secret URL token (?key=...), on
# top of the password login. Leave unset for an open instance.
# Generate one with: openssl rand -hex 16
ACCESS_KEY=
